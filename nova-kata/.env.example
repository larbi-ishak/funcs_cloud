PORT=3002
NODE_ENV=development
DB_PATH=./data/nova-kata.db
HEALTH_CHECK_INTERVAL_MS=30000
MAX_CONSECUTIVE_FAILURES=3
SSH_CONNECT_TIMEOUT=10000
SSH_EXEC_TIMEOUT=30000

# Container defaults
# Shared Docker registry host:port (internal IP for GCP same-subnet, or localhost:5000 for dev)
REGISTRY_HOST=10.128.0.21:5000
# Gateway URL for cache invalidation notifications
GATEWAY_URL=http://localhost:8081
DEFAULT_IMAGE=10.128.0.21:5000/nova-fn-hello:latest
DEFAULT_RUNTIME=io.containerd.kata.v2
DEFAULT_SNAPSHOTTER=overlayfs
DEFAULT_AGENT_CMD=python3 /nova_agent.py
DEFAULT_AGENT_PORT=8080

# Warm pool
WARM_POOL_MIN=2
WARM_POOL_MAX=10
WARM_POOL_REPLENISH_INTERVAL_MS=15000

# ── GCP Auto-Scaling ──────────────────────────────────────────────────────────
# Required: your GCP project ID
GCP_PROJECT_ID=your-gcp-project-id

# Path to a service account JSON key file (leave blank to use ADC)
GCP_KEY_FILE=/path/to/service-account.json

# Root password injected into new VMs via startup script (must be strong)
GCP_VM_ROOT_PASSWORD=NovaWorker2025!

# Machine type for new worker VMs (must support nested virtualisation)
GCP_MACHINE_TYPE=n2-standard-2

# Boot disk size in GB
GCP_DISK_SIZE_GB=100

# Default logical region for auto-scaled workers
# Options: us, us-east, us-west, europe, eu-west, asia, asia-se, africa, me
GCP_DEFAULT_REGION=us

# Scale-out when cluster utilisation exceeds this fraction (0.0–1.0)
SCALE_OUT_THRESHOLD=0.75

# Maximum total workers (cost guard — never exceed this count)
MAX_WORKERS=5

# Minutes to wait between consecutive scale-out events (cool-down)
SCALE_OUT_COOLDOWN_MIN=10
