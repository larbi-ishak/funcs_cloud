# ── Nova Kata Gateway Configuration ──────────────────────────────────────

# Gateway ports
GATEWAY_PORT=8081
INTERNAL_PORT=3003

# Database path (relative to project root)
DB_PATH=../nova-kata/data/nova-kata.db

# Placement service URL (Nova Kata)
PLACEMENT_SERVICE_URL=http://localhost:3002

# Container idle TTL (seconds) — how long a container stays warm between requests
CONTAINER_IDLE_TTL=30

# Function metadata cache TTL (seconds) — how long function data is cached before re-querying DB.
# Default: 3600 (1 hour). Function metadata rarely changes; cache is invalidated
# explicitly via POST /internal/invalidate when admin changes settings.
# Lower values = more DB queries but faster consistency. Higher = fewer queries.
FUNCTION_CACHE_TTL=3600

# ── Redis Cache ───────────────────────────────────────────────────────────
# Set REDIS_URL to enable Redis as the shared cache backend.
# Leave empty to use in-memory cache (node-cache) — suitable for single-instance dev.
#
# Local dev (no Redis):     REDIS_URL=
# Local dev (Docker Redis): REDIS_URL=redis://localhost:6379
# Production (with auth):   REDIS_URL=redis://:your-password@redis-host:6379
REDIS_URL=

# ── Logging ───────────────────────────────────────────────────────────────
# Log level: trace, debug, info, warn, error, fatal
# Production: info (timing logs at debug level are zero-cost when disabled)
# Development: debug
LOG_LEVEL=

# Node environment
NODE_ENV=development