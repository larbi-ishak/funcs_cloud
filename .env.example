# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/placement.db

# Monitoring
HEALTH_CHECK_INTERVAL_MS=30000
MAX_CONSECUTIVE_FAILURES=3

# SSH connection timeout (ms)
SSH_CONNECT_TIMEOUT=10000
SSH_EXEC_TIMEOUT=30000

# Firecracker defaults (can be overridden per worker at /init)
DEFAULT_FIRECRACKER_PATH=/usr/local/bin/firecracker
DEFAULT_KERNEL_IMAGE_PATH=/root/lab/hello-vmlinux.bin
DEFAULT_ROOTFS_PATH=/root/lab/hello-rootfs.ext4

# Firecracker socket directory on remote workers
FC_SOCKET_DIR=/tmp/fc-sockets
